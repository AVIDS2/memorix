{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "./dist",
		"jsx": "react-jsx",
		"jsxImportSource": "@opentui/react",
		"paths": {
			"@memorix/agent-core": ["../agent-core/dist/index.d.ts"],
			"@memorix/agent-core/*": ["../agent-core/dist/*.d.ts"],
			"@memorix/ai": ["../ai/dist/index.d.ts"],
			"@memorix/ai/*": ["../ai/dist/*.d.ts", "../ai/dist/providers/*.d.ts"],
			"@memorix/tui": ["../tui/dist/index.d.ts"],
			"@memorix/tui/*": ["../tui/dist/*.d.ts", "../tui/dist/components/*.d.ts"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
	"exclude": ["node_modules", "dist", "src/tui/**"]
}
