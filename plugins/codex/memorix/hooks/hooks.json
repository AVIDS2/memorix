          {
            "type": "command",
            "command": "memorix hook --agent codex",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "memorix hook --agent codex",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "memorix hook --agent codex",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
