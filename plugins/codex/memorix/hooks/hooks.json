{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "memorix hook --agent codex",
            "commandWindows": "memorix.cmd hook --agent codex",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "memorix hook --agent codex",
            "commandWindows": "memorix.cmd hook --agent codex",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "memorix hook --agent codex",
            "commandWindows": "memorix.cmd hook --agent codex",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "memorix hook --agent codex",
            "commandWindows": "memorix.cmd hook --agent codex",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "memorix hook --agent codex",
            "commandWindows": "memorix.cmd hook --agent codex",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
