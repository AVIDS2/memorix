+package cobra
+
+import "testing"
+
+func TestCompletionInputOwnsCompletedArguments(t *testing.T) {
+	args := make([]string, 3, 4)
+	copy(args, []string{"root", ShellCompNoDescRequestCmd, "typed"})
+
+	completed, incomplete := completionInput(args)
+	if incomplete != "typed" {
+		t.Fatalf("incomplete word = %q, want %q", incomplete, "typed")
+	}
+	completed = append(completed, "--")
+
+	if args[2] != "typed" {
+		t.Fatalf("completion processing rewrote caller argument: got %q, want %q", args[2], "typed")
+	}
+}
