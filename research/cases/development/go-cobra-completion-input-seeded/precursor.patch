+// completionInput separates the incomplete word from the completed arguments.
+//
+// Completion parsing may append a sentinel to the completed arguments. Keep the
+// caller-owned slice independent so processing completion cannot rewrite the
+// incomplete word in the original input.
+func completionInput(args []string) (trimmedArgs []string, toComplete string) {
+	toComplete = args[len(args)-1]
+	trimmedArgs = append([]string(nil), args[:len(args)-1]...)
+	return trimmedArgs, toComplete
+}
