diff --git a/service/retry_hidden_test.go b/service/retry_hidden_test.go
new file mode 100644
--- /dev/null
+++ b/service/retry_hidden_test.go
@@ -0,0 +1,30 @@
+package service
+
+import (
+    "testing"
+    "time"
+)
+
+func TestAcceptsMinimumRetryDelay(t *testing.T) {
+    if got := ScheduleRetry(375 * time.Millisecond); got != 375*time.Millisecond {
+        t.Fatalf("unexpected delay: %s", got)
+    }
+}
+
+func TestAcceptsNextRetryCadence(t *testing.T) {
+    if got := ScheduleRetry(500 * time.Millisecond); got != 500*time.Millisecond {
+        t.Fatalf("unexpected delay: %s", got)
+    }
+}
+
+func TestRejectsDelayOneMillisecondBelowPolicy(t *testing.T) {
+    if !panics(func() { ScheduleRetry(374 * time.Millisecond) }) {
+        t.Fatal("expected a delay below policy minimum to panic")
+    }
+}
+
+func TestRejectsDelayOffTheSchedulerCadence(t *testing.T) {
+    if !panics(func() { ScheduleRetry(400 * time.Millisecond) }) {
+        t.Fatal("expected a delay off the scheduler cadence to panic")
+    }
+}
