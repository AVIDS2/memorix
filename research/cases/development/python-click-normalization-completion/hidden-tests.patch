+
+
+def test_option_normalizer_receives_name_without_prefix(runner):
+    def normalize_token(token):
+        if token.startswith("-"):
+            raise AssertionError("option prefix reached token normalizer")
+        return token.lower()
+
+    @click.command(context_settings={"token_normalize_func": normalize_token})
+    @click.option("--mode", type=click.Choice(["fast", "safe"]))
+    def cli(mode):
+        click.echo(mode)
+
+    result = runner.invoke(cli, ["--MODE", "fast"])
+    assert not result.exception, result.output
+    assert result.output == "fast\n"
