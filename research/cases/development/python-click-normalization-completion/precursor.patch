+def test_token_normalization_completion():
+    context_settings = {"token_normalize_func": str.lower}
+    cli = Command(
+        "cli",
+        context_settings=context_settings,
+        params=[Option(["--mode"], type=Choice(["fast", "safe"]))],
+    )
+
+    assert _get_words(cli, [], "--MO") == ["--mode"]
+    assert _get_words(cli, ["--MODE"], "F") == ["fast"]
+
+    group = Group(
+        "cli",
+        context_settings=context_settings,
+        commands={"deploy": Command("deploy")},
+    )
+    assert _get_words(group, [], "DE") == ["deploy"]
+
+
 def test_choice_special_characters():
     cli = Command("cli", params=[Option(["-c"], type=Choice(["!1", "!2", "+3"]))])
     assert _get_words(cli, ["-c"], "") == ["!1", "!2", "+3"]
