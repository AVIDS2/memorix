diff --git a/tests/token-policy.hidden.test.mjs b/tests/token-policy.hidden.test.mjs
new file mode 100644
--- /dev/null
+++ b/tests/token-policy.hidden.test.mjs
@@ -0,0 +1,20 @@
+import assert from 'node:assert/strict';
+import test from 'node:test';
+
+import { createSession } from '../src/session.js';
+
+test('accepts the minimum policy-compliant token length', () => {
+  assert.deepEqual(createSession('tok_alpha7bravo9xy'), { token: 'tok_alpha7bravo9xy' });
+});
+
+test('rejects a prefixed token one character below the policy minimum', () => {
+  assert.throws(() => createSession('tok_alpha7bravo9x'));
+});
+
+test('rejects a long prefixed token without an issuer shard marker', () => {
+  assert.throws(() => createSession('tok_alphabravoxyzt'));
+});
+
+test('rejects a prefix-only token', () => {
+  assert.throws(() => createSession('tok_'));
+});
